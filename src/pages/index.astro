---
import { Icon } from "astro-icon/components";
import "../styles/global.css";

// Pixel slashed-zero glyph — two-tone: 1 = text color, 2 = red.
const zero = [
    [0, 1, 1, 2, 2, 0],
    [1, 0, 0, 0, 2, 2],
    [1, 0, 0, 2, 0, 2],
    [1, 0, 1, 0, 0, 2],
    [1, 1, 0, 0, 0, 2],
    [0, 1, 1, 2, 2, 0],
];

const info = [
    ["OS", "macOS &amp; arch <span class='text-ctp-overlay1'>(btw)</span>"],
    ["Host", "Bengaluru, IN (UTC+5:30)"],
    ["Uptime", "4 years, 0 kernel panics"],
    ["Packages", "gin, sqlc, fastapi, postgres, zod"],
    ["Editor", "neovim <span class='text-ctp-overlay1'>(btw)</span>"],
    ["Battery", "100% <span class='text-ctp-overlay1'>(coffee-powered)</span>"],
];

const palette = [
    "bg-ctp-surface1",
    "bg-ctp-red",
    "bg-ctp-green",
    "bg-ctp-yellow",
    "bg-ctp-blue",
    "bg-ctp-pink",
    "bg-ctp-teal",
    "bg-ctp-subtext0",
];

const projects = [
    {
        name: "trex/",
        repo: "https://github.com/samyakbardiya/trex",
        desc: "Go TUI for real-time RegEx · 2nd prize, FOSS Hack 2025 · <span class='inline-flex items-center gap-1 text-ctp-yellow'><i class='fa-solid fa-star text-xs sm:text-sm relative -top-px'></i>120+</span>",
    },
    {
        name: "dotfiles/",
        repo: "https://github.com/samyakbardiya/dotfiles",
        desc: "the repo that actually matters",
    },
];

const prs = [
    {
        num: "#25",
        project: "portik",
        desc: "stateful directory context across restarts",
        pr: "https://github.com/pratik-anurag/portik/pull/25",
    },
    {
        num: "#5",
        project: "unduck",
        desc: "tightened RegEx edge cases",
        pr: "https://github.com/T3-Content/unduck/pull/5",
    },
    {
        num: "#14",
        project: "yang",
        desc: "added Chromium support",
        pr: "https://github.com/dmlls/yang/pull/14",
    },
];

const contacts = [
    {
        icon: "fa6-solid:envelope",
        iconCls: "text-ctp-peach",
        label: "mail@samyakbardiya.dev",
        href: "mailto:mail@samyakbardiya.dev",
        date: "2024-01-14",
    },
    {
        icon: "fa6-brands:github-alt",
        iconCls: "text-ctp-mauve",
        label: "github.com/samyakbardiya",
        href: "https://github.com/samyakbardiya",
        date: "2016-11-09",
    },
    {
        icon: "fa6-brands:x-twitter",
        iconCls: "text-ctp-lavender",
        label: "x.com/samyakbardiya",
        href: "https://x.com/samyakbardiya",
        date: "2014-08-16",
    },
    {
        icon: "fa6-brands:linkedin-in",
        iconCls: "text-ctp-sapphire",
        label: "linkedin.com/in/samyakbardiya",
        href: "https://linkedin.com/in/samyakbardiya",
        date: "2018-08-15",
    },
];

const link = "text-ctp-sky font-medium hover:text-ctp-mauve hover:underline";
const alink = "text-ctp-blue hover:text-ctp-mauve hover:underline break-words";
---

<html lang="en" class="mocha" data-theme="mocha">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <link rel="preconnect" href="https://fonts.cdnfonts.com" />
        <link href="https://fonts.cdnfonts.com/css/input-mono.styles" rel="stylesheet" />

        <title>samyak bardiya</title>
        <meta
            name="description"
            content="Samyak Bardiya - software engineer, back-end, & nerd for tech."
        />

        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://samyakbardiya.dev" />
        <meta property="og:title" content="samyak bardiya" />
        <meta
            property="og:description"
            content="Samyak Bardiya - software engineer, back-end, & nerd for tech."
        />
        <meta property="og:image" content="https://samyakbardiya.dev/og.png" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:site" content="@samyakbardiya" />
        <meta name="twitter:title" content="samyak bardiya" />
        <meta
            name="twitter:description"
            content="Samyak Bardiya - software engineer, back-end, & nerd for tech."
        />
        <meta name="twitter:image" content="https://samyakbardiya.dev/og.png" />

        <script is:inline>
            // Apply the saved theme before first paint to avoid a flash.
            (function () {
                try {
                    const t = localStorage.getItem("sb-theme");
                    if (t) {
                        document.documentElement.setAttribute("data-theme", t);
                        document.documentElement.classList.toggle("mocha", t === "mocha");
                        document.documentElement.classList.toggle("latte", t === "latte");
                    }
                } catch (e) {}
            })();
        </script>
    </head>

    <body
        class="flex min-h-screen items-start justify-center bg-ctp-base p-5 font-mono text-ctp-text"
    >
        <main
            class="relative w-full max-w-300 bg-ctp-base px-4 py-5 text-sm leading-6 sm:px-9 sm:py-8 sm:text-base sm:leading-7"
        >
            <!-- whoami -->
            <div class="my-6 sm:my-4">
                <div
                    class="flex animate-boot items-center justify-between opacity-0 [animation-delay:0.2s]"
                >
                    <div>
                        <span class="text-ctp-green">❯</span> whoami
                    </div>
                    <button
                        type="button"
                        id="theme-toggle"
                        aria-label="Toggle color theme"
                        class="cursor-pointer border-0 bg-transparent p-0 text-sm text-ctp-overlay1 select-none hover:text-ctp-text sm:text-base"
                    >
                        <Icon name="fa6-solid:moon" class="theme-icon-moon" />
                        <Icon name="fa6-solid:sun" class="theme-icon-sun" />
                    </button>
                </div>
                <div class="animate-boot opacity-0 [animation-delay:0.4s]">
                    <div class="mt-1 mb-0.5 text-xl font-bold sm:text-2xl">samyak bardiya</div>
                    <div class="text-ctp-overlay1">
                        # software engineer · back-end
                        <span class="hidden sm:inline"> · </span>
                        <br class="sm:hidden" />
                        <span class="sm:hidden"># </span>
                        <!-- go &amp; distributed systems -->
                        nerd for tech
                    </div>
                </div>
            </div>

            <!-- neofetch -->
            <div class="my-1 mb-5 sm:my-4 sm:mb-6">
                <div class="animate-boot opacity-0 [animation-delay:0.8s]">
                    <span class="text-ctp-green">❯</span> neofetch
                </div>
                <div
                    class="flex animate-boot flex-col opacity-0 [animation-delay:1.1s] sm:flex-row sm:items-start sm:gap-10"
                >
                    <div
                        role="img"
                        aria-label="slashed zero glyph"
                        class="my-3 grid auto-rows-2.25 grid-cols-[repeat(6,9px)] gap-px self-start drop-shadow-[0_0_8px_var(--color-glow)] sm:mb-0 sm:auto-rows-2.75 sm:grid-cols-[repeat(6,11px)] sm:self-center"
                    >
                        {zero.flat().map((c) => <span class={c === 0 ? "" : "bg-ctp-red"} />)}
                    </div>
                    <div class="min-w-0 flex-1">
                        <div>
                            <span class="font-bold text-ctp-blue">zero</span>
                            <span class="text-ctp-overlay1">@</span>
                            <span class="font-bold text-ctp-blue">samyakbardiya.dev</span>
                        </div>
                        <div class="text-ctp-surface1">----------------------</div>
                        <div
                            class="grid grid-cols-[76px_1fr] gap-x-2.5 sm:grid-cols-[96px_1fr] sm:gap-x-3"
                        >
                            {
                                info.map(([k, v]) => (
                                    <>
                                        <span class="text-ctp-yellow">{k}</span>
                                        <span set:html={v} />
                                    </>
                                ))
                            }
                        </div>
                        <div class="mt-3 flex">
                            {palette.map((c) => <span class={`h-5 w-8 sm:h-6 sm:w-9 ${c}`} />)}
                        </div>
                    </div>
                </div>
            </div>

            <!-- projects -->
            <div class="my-6 sm:my-4">
                <div class="animate-boot opacity-0 [animation-delay:1.5s]">
                    <span class="text-ctp-green">❯ </span>
                    eza ~/projects
                    <span class="hidden sm:inline"> --oneline</span>
                    &nbsp;--sort=stars
                </div>
                <div
                    class="my-0.5 flex animate-boot flex-col gap-1.5 opacity-0 [animation-delay:1.7s] sm:grid sm:grid-cols-[150px_1fr] sm:gap-x-4 sm:gap-y-0.5"
                >
                    {
                        projects.map((p) => (
                            <div class="block sm:contents">
                                <a href={p.repo} class={link} target="_blank" rel="noopener">
                                    {p.name}
                                </a>
                                <span class="block text-ctp-subtext0 sm:inline" set:html={p.desc} />
                            </div>
                        ))
                    }
                </div>
            </div>

            <!-- merged PRs -->
            <div class="my-6 sm:my-4">
                <div class="animate-boot opacity-0 [animation-delay:1.85s]">
                    <span class="text-ctp-green">❯ </span>
                    gh pr list --author @me
                    <span class="text-ctp-overlay1 sm:hidden"> \ </span>
                    <br class="sm:hidden" />
                    <span class="sm:hidden"> &nbsp;&nbsp;&nbsp;&nbsp;--state merged </span>
                    <span class="hidden sm:inline"> --state merged</span>
                </div>
                <div
                    class="my-0.5 flex animate-boot flex-col gap-1.5 opacity-0 [animation-delay:1.95s] sm:grid sm:grid-cols-[64px_110px_1fr] sm:gap-x-4 sm:gap-y-0.5"
                >
                    {
                        prs.map((p) => (
                            <div class="block sm:contents">
                                <a
                                    href={p.pr}
                                    class="text-ctp-green hover:font-bold hover:underline"
                                    target="_blank"
                                    rel="noopener"
                                >
                                    {p.num}
                                </a>
                                <a
                                    href={p.pr}
                                    class={`${link} mx-3 sm:mx-0`}
                                    target="_blank"
                                    rel="noopener"
                                >
                                    {p.project}
                                </a>
                                <span class="block text-ctp-subtext0 sm:inline">{p.desc}</span>
                            </div>
                        ))
                    }
                </div>
            </div>

            <!-- contacts -->
            <div class="my-6 sm:my-4">
                <div class="animate-boot opacity-0 [animation-delay:2s]">
                    <span class="text-ctp-green">❯ </span>
                    eza ~/contacts --icons
                    <span class="hidden sm:inline"> --long</span>
                </div>
                <div
                    class="my-0.5 grid animate-boot grid-cols-[20px_1fr] items-baseline justify-start gap-x-2 gap-y-0.5 opacity-0 [animation-delay:2.2s] sm:grid-cols-[auto_auto_20px_auto] sm:gap-x-3.5"
                >
                    {
                        contacts.map((c) => (
                            <div class="contents">
                                <span class="hidden text-ctp-green sm:inline">.rw-r--r--</span>
                                <span class="hidden text-ctp-overlay1 sm:inline">{c.date}</span>
                                <Icon name={c.icon} class={c.iconCls} />
                                <a href={c.href} class={alink}>
                                    {c.label}
                                </a>
                            </div>
                        ))
                    }
                </div>
            </div>

            <!-- exit -->
            <div class="my-6 sm:my-4">
                <div class="animate-boot opacity-0 [animation-delay:2.5s]">
                    <span class="text-ctp-green">❯</span> exit
                </div>
                <div class="animate-boot text-ctp-overlay1 opacity-0 [animation-delay:2.7s]">
                    logout
                    <br />
                    Connection<span class="hidden sm:inline"> to samyakbardiya.dev</span> closed.&nbsp;
                    <span class="text-ctp-red">segfault avoided</span> - core not dumped, memories kept.
                </div>
            </div>
        </main>

        <style is:inline>
            .theme-icon-moon {
                display: inline-block;
            }
            .theme-icon-sun {
                display: none;
            }
            [data-theme="latte"] .theme-icon-moon {
                display: none;
            }
            [data-theme="latte"] .theme-icon-sun {
                display: inline-block;
            }
        </style>

        <script is:inline>
            (function () {
                const btn = document.getElementById("theme-toggle");
                const root = document.documentElement;
                btn.addEventListener("click", function () {
                    const next = root.getAttribute("data-theme") === "mocha" ? "latte" : "mocha";
                    root.setAttribute("data-theme", next);
                    root.classList.toggle("mocha", next === "mocha");
                    root.classList.toggle("latte", next === "latte");
                    try {
                        localStorage.setItem("sb-theme", next);
                    } catch (e) {}
                });
            })();
        </script>
    </body>
</html>
